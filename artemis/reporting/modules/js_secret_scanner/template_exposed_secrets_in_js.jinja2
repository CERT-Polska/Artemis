{% if "exposed_secrets_in_js" in data.contains_type %}
    <li>{% trans %}The following addresses expose secrets (such as API keys, tokens, or credentials) in JavaScript files:{% endtrans %}
        <ul>
            {% for report in data.reports %}
                {% if report.report_type == "exposed_secrets_in_js" %}
                    <li>
                        {{ report.target }}:
                        {% for secret_type in report.additional_data.secret_types %}
                            {{ secret_type }}{% if not loop.last %}, {% endif %}
                        {% endfor %}
                        {{ report_meta(report) }}
                    </li>
                {% endif %}
            {% endfor %}
        </ul>
        <p>
            {% trans trimmed %}
                Hardcoded secrets in JavaScript files are accessible to anyone visiting the website.
                API keys, access tokens, and credentials exposed this way can be used by attackers
                to gain unauthorized access to backend services, databases, or third-party APIs.
                We recommend removing all secrets from client-side code and using server-side
                proxies or environment variables instead.
            {% endtrans %}
        </p>
    </li>
{% endif %}
