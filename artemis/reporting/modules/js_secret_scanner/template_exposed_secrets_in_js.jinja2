{% if "exposed_secrets_in_js" in data.contains_type %}
    <li>{% trans %}We found secrets exposed in JavaScript on the following targets:{% endtrans %}
        <ul>
            {% for report in data.reports %}
                {% if report.report_type == "exposed_secrets_in_js" %}
                    <li>
                        {{ report.target }} ({{ report.additional_data.high_count }} high, {{ report.additional_data.medium_count }} medium)
                        <ul>
                            {% for finding in report.additional_data.findings %}
                                <li>[{{ finding.severity | upper }}] {{ finding.pattern_name }} — {{ finding.js_url }} ({{ finding.matched_text_redacted }})</li>
                            {% endfor %}
                        </ul>
                    </li>
                {% endif %}
            {% endfor %}
        </ul>
    </li>
{% endif %}
