{% extends "components/base.jinja2" %}

{% block main %}
    <h1>Analysed targets</h1>
    <p>
        Total pending tasks: {{ num_active_tasks }}
    </p>

    {% if has_analyses %}
        <table id="analysis_list" class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">Created at</th>
                    <th scope="col">Target</th>
                    <th scope="col">Tag</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
        </table>
        <p>
            <a class="btn btn-primary" href="{{ request.url_for('get_results') }}?task_filter=interesting">Show results for all targets</a>

            {% if has_finished_analyses %}
                <a class="btn btn-danger" href="#" data-bs-toggle="modal" data-bs-target="#remove-finished-analyses-modal">Remove finished analyses</a>
            {% endif %}
        </p>
        <p>
            Hint: Browse to the <a href="{{ request.url_for('get_queue') }}">task queue</a> to see how the tasks are progressing.
        </p>
    {% else %}
        No targets have yet been analysed. <a href="{{ request.url_for('get_add_form') }}">Analyze targets.</a>
    {% endif %}

    <!-- Modal for Remove Pending Tasks Confirmation -->
    <div class="modal" tabindex="-1" role="dialog" id="remove-pending-tasks-modal" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Remove pending tasks</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        You are about to remove pending tasks from the analysis of <code id="modal-analysed-object"></code>.
                        <b>Tasks currently running will finish.</b>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form id="remove-pending-tasks-form" method="POST" style="display: inline;">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
                        <button type="submit" class="btn btn-danger">Remove</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Remove All Finished Analyses Confirmation -->
    <div class="modal" tabindex="-1" role="dialog" id="remove-finished-analyses-modal" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Remove all finished analyses</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        This will remove the finished analyses (with the <b>done</b> badge) from the table on the homepage. The
                        corresponding task results will still be in the database and you will still be able to
                        <a href="{{ request.url_for('get_export_form') }}">export them</a> or view them on the
                        <a href="{{ request.url_for('get_results') }}?task_filter=interesting">all task results</a> list.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="POST" action="{{ request.url_for('post_remove_finished_analyses') }}" style="display: inline;">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
                        <button type="submit" class="btn btn-danger">Remove</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block scripts %}
    <script>
        $(document).ready(function() {
            const table = $("#analysis_list").dataTable({
                ajax: {{ api_url|tojson }},  // we want to prevent & being converted to &amp; here
                pageLength: 10,
                serverSide: true,
                columnDefs: [{
                    "targets": [3, 4],
                    "orderable": false
                }]
            });

            table.on('draw.dt', function () {
                $('[data-bs-toggle="tooltip"]').tooltip();

                // Handle remove pending tasks modal
                $('.remove-pending-tasks-link').off('click').on('click', function() {
                    const analysisId = $(this).data('analysis-id');
                    const analysisTarget = $(this).data('analysis-target');

                    $('#modal-analysed-object').text(analysisTarget);
                    $('#remove-pending-tasks-form').attr('action', '/analysis/remove-pending-tasks/' + analysisId);
                });
            });
        })
    </script>
{% endblock %}
