{% extends "components/base.jinja2" %}
{% block main %}
    <h1>Log in</h1>

    {% if not credentials_configured %}
        <div class="alert alert-info" role="alert">
            No frontend credentials configured. Set <tt>FRONTEND_USERNAME</tt> and <tt>FRONTEND_PASSWORD</tt>
            in your <tt>.env</tt> file to enable login. The API remains reachable at <tt>/api/*</tt> using
            the <tt>X-API-Token</tt> header.
        </div>
    {% endif %}

    {% if error %}
        <div class="alert alert-danger" role="alert">
            {{ error }}
        </div>
    {% endif %}

    <form action="{{ request.url_for('post_login') }}" method="post" class="w-100" style="max-width: 400px;">
        <div class="form-group mb-3">
            <label class="form-label">Username</label>
            <input class="form-control" type="text" name="username" autocomplete="username" required autofocus>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Password</label>
            <input class="form-control" type="password" name="password" autocomplete="current-password" required>
        </div>
        <input type="submit" class="btn btn-primary" value="Log in">
    </form>
{% endblock %}
